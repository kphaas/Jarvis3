#!/bin/zsh
set -euo pipefail

if [ $# -lt 1 ]; then
  echo "usage: gfetch <url>" >&2
  exit 2
fi

TOKEN="$(security find-generic-password -a token -s jarvis.gateway.v1 -w)"

BODY="$(python3 - "$1" <<'PY'
import json, sys
print(json.dumps({"url": sys.argv[1]}))
PY
)"

RESP="$(curl -sS --fail-with-body --max-time 20 \
  http://100.112.63.25:8282/fetch \
  -H "Content-Type: application/json" \
  -H "x-jarvis-token: $TOKEN" \
  -d "$BODY" || true)"

# Pretty-print if it's JSON
python3 - <<'PY' "$RESP" 2>/dev/null || echo "$RESP"
import json, sys
print(json.dumps(json.loads(sys.argv[1]), indent=2))
PY
